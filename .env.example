# Environment Variables Configuration

# Backend Server
PORT=3001
FRONTEND_URL=http://localhost
API_BASE_URL=http://localhost:3001

# OpenRouter API Key (Required - enforced server-side only)
# Get your API key from: https://openrouter.ai/keys
# SECURITY: Never expose this key to the frontend
OPEN_ROUTER_API_KEY=your_openrouter_api_key_here

# Sentry Error Tracking (Optional but Recommended for Production)
# Get DSN from: https://sentry.io/
SENTRY_DSN=

# JWT Secret for Authentication
JWT_SECRET=

# Admin Key for Cache Management (Optional)
# Generate a secure random string
ADMIN_KEY=

# Node Environment
# choose: auto | openrouter | ollama
AI_PROVIDER=auto

# OpenRouter (cloud)
OPENROUTER_API_KEY=...
OPENROUTER_MODEL=openai/gpt-5-nano  # pick whatever you want
OPENROUTER_SITE_URL=https://ai-visibility-search.vercel.app/
OPENROUTER_APP_NAME=Evidence-backed site analysis for AI answers Platform

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

