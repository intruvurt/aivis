# ─── Client Environment (Vite) ─────────────────────────────────────────────────
# Only VITE_* vars are exposed to the browser bundle.
# NEVER put API keys, secrets, or DB URLs here — they will be PUBLIC.
#
# For server env vars see: ../server/.env.example

# Backend API base URL
#  
#   Prod: https://api.aivis.biz  ← set this in Render dashboard for the static site too
VITE_API_URL=https://api.aivis.biz

# Stripe publishable key — safe to expose (public key only, never the secret)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...  # copy from Stripe Dashboard > API keys

# Sentry DSN for client error tracking (optional — DSNs are designed to be public)
VITE_SENTRY_DSN=

