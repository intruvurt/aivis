{
  "name": "aivis-cite-ledger",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.6",
    "npm": ">=11.6.1"
  },
  "scripts": {
    "dev": "vite",
    "build:validate": "node ./scripts/validate-route-intelligence.mjs",
    "build:app": "vite build",
    "build:prerender": "node ./scripts/prerender-routes.mjs",
    "build": "npm run build:validate && npm run build:app && npm run build:prerender",
    "preview": "vite preview",
    "blog:sync": "node ./scripts/sync-blog-ready.mjs",
    "mobile:assets": "npm exec --yes -- @capacitor/assets generate --assetPath resources",
    "mobile:prepare": "node ./scripts/mobile-prepare.cjs",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "eslint . --config eslint.config.cjs --ext .ts,.tsx",
    "lint:fix": "eslint . --config eslint.config.cjs --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "analyze:routes": "node ./scripts/validate-route-intelligence.mjs",
    "analyze:seo": "node ./scripts/analyze-cite-graph.mjs",
    "audit:full": "npm run typecheck && npm run lint && npm run test:run && npm run build"
  },
  "dependencies": {
    "@sentry/react": "^10.39.0",
    "@stripe/stripe-js": "9.2.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "5.99.0",
    "ajv": "^8.18.0",
    "axios": "^1.13.5",
    "cypress": "^15.14.1",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.34.2",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "1.8.0",
    "posthog-js": "^1.279.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@cloudflare/playwright": "^1.3.0",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "happy-dom": "^20.6.3",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "undici": "^7.3.0",
    "esbuild": "^0.25.0",
    "got": "^12.6.0",
    "path-to-regexp": "^8.2.0",
    "qs": "^6.14.1",
    "minimatch": ">=10.2.1",
    "systeminformation": ">=5.30.8",
    "@types/node": "^25.0.9"
  }
}
