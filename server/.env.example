# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
AI_PROVIDER=auto                      # auto | openrouter | ollama
ADMIN_KEY=                            # Set to a random string for admin routes
SESSION_SECRET=                       # Express session secret (random 32+ chars)

# ─── URLs / CORS ───────────────────────────────────────────────────────────────
# FRONTEND_URL is the canonical var the server reads for CORS, email links,
# and Stripe redirect URLs. Comma-separate multiple origins for dev.
FRONTEND_URL=
APP_URL=https://aivis.biz
BACKEND_URL=                          # Full backend URL (e.g. https://api.aivis.biz)
API_URL=                              # Alias for backend URL if needed

# ─── Database (Postgres) ───────────────────────────────────────────────────────
DATABASE_URL=                         # postgresql://user:pass@host/db?sslmode=require
PG_SSL=true                           # Use SSL for Postgres connection
DB_MIGRATION_MAX_RETRIES=3            # Max retries for DB migration on startup

# ─── Redis (optional - session/cache) ─────────────────────────────────────────
REDIS_URL=                            # redis://host:6379 - if not set, falls back to in-memory

# ─── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=                           # REQUIRED: Set to a long random string (32+ chars)
JWT_EXPIRE=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=                   # General-purpose encryption key (32+ chars)
PUBLIC_REPORT_SIGNING_SECRET=         # AES-256-GCM key for public share tokens (falls back to JWT_SECRET)
API_KEY_PEPPER=                       # Extra pepper for API key hashing

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPEN_ROUTER_API_KEY=                  # Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=                   # Alias - either var name works
OPEN_ROUTER_SITE_URL=https://aivis.biz
OPEN_ROUTER_APP_NAME=AiVis
OLLAMA_BASE_URL=                      # Only needed for local Ollama inference
OLLAMA_API_KEY=
GEMINI_API_KEY=                       # Google Gemini API key (optional fallback provider)
AI_CALL_TIMEOUT_MS=30000              # Per-call timeout for AI provider requests (ms)

# ─── Scraping / Puppeteer ─────────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=            # Custom Chrome path (auto-detected if blank)
PUPPETEER_LAUNCH_TIMEOUT_MS=30000     # Browser launch timeout
SCRAPE_BUDGET_MS=20000                # Max time budget for page scraping
ALLOW_PRIVATE_ANALYZE_TARGETS=false   # true allows localhost/private IPs (dev only!)

# ─── Analysis pipeline ────────────────────────────────────────────────────────
ANALYZE_REENTRANCY_GUARD_ENABLED=true
ANALYZE_LOCK_TTL_MS=120000
STRICT_LIVE_SOFT_FAIL_ENABLED=false   # If true, soft-fail on strict rubric live checks

# ─── Email - Resend ────────────────────────────────────────────────────────────
# Without RESEND_API_KEY, verification links print to console only (dev fallback).
RESEND_API_KEY=                       # Get from https://resend.com/api-keys
FROM_EMAIL=noreply@aivis.biz
RESEND_WEBHOOK_SECRET=                # whsec_... - from Resend Webhooks

# ─── Newsletter automation ────────────────────────────────────────────────────
NEWSLETTER_AUTOMATION_ENABLED=false   # Enable automated newsletter send loop
NEWSLETTER_INTERVAL_MS=86400000       # Interval between newsletter batches (ms)
NEWSLETTER_BATCH_SIZE=50              # Number of emails per batch
NEWSLETTER_SEND_DELAY_MS=1000         # Delay between individual sends (rate limit)
NEWSLETTER_AUTOMATION_DEFAULT=false   # Auto-subscribe new users to newsletter

# ─── CORS ──────────────────────────────────────────────────────────────────────
# FRONTEND_URL already controls CORS - CORS_ORIGIN is a secondary override
CORS_ORIGIN=https://aivis.biz,https://www.aivis.biz

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: https://api.aivis.biz/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: https://api.aivis.biz/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google Search Console (GSC Intelligence) ─────────────────────────────────
# console.cloud.google.com → APIs → Enable "Search Console API"
# Create a separate OAuth 2.0 Client ID for GSC (Web application type)
GSC_GOOGLE_CLIENT_ID=                 # OAuth2 Client ID for GSC
GSC_GOOGLE_CLIENT_SECRET=             # OAuth2 Client Secret for GSC
GSC_OAUTH_CALLBACK_URL=              # e.g. https://api.aivis.biz/api/integrations/gsc/oauth/callback
GSC_OAUTH_STATE_SECRET=               # Random string for CSRF state param signing
GSC_TOKEN_ENCRYPTION_KEY=             # AES key for encrypting stored GSC tokens (32+ chars)

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=               # pk_live_... (also set as VITE_STRIPE_PUBLISHABLE_KEY in client/.env)
STRIPE_SECRET_KEY=                    # sk_live_... - NEVER expose to client
STRIPE_WEBHOOK_SECRET=                # whsec_... - from Stripe Webhooks > Signing secret
STRIPE_MODE=live                      # live | test

# Subscription price IDs (create these in Stripe Dashboard → Products)
STRIPE_ALIGNMENT_MONTHLY_PRICE_ID=
STRIPE_ALIGNMENT_YEARLY_PRICE_ID=
STRIPE_SIGNAL_MONTHLY_PRICE_ID=
STRIPE_SIGNAL_YEARLY_PRICE_ID=
STRIPE_AutoFix PR_PRICE_ID=            # one-time Score Fix price ID (preferred)
STRIPE_AutoFix PR_MONTHLY_PRICE_ID=
STRIPE_AutoFix PR_YEARLY_PRICE_ID=

# Scan pack (one-time credit bundle) price IDs
STRIPE_SCAN_PACK_25_PRICE_ID=        # 25-scan pack
STRIPE_SCAN_PACK_100_PRICE_ID=       # 100-scan pack
STRIPE_SCAN_PACK_115_PRICE_ID=       # 115-scan pack
STRIPE_SCAN_PACK_120_PRICE_ID=       # 120-scan pack  ($19)
STRIPE_SCAN_PACK_275_PRICE_ID=       # 275-scan pack
STRIPE_SCAN_PACK_400_PRICE_ID=       # 400-scan pack  ($69)

# Legacy Stripe price IDs (alias mapping)
STRIPE_PRO_PRICE_ID=                  # Legacy pro tier price
STRIPE_BUSINESS_PRICE_ID=            # Legacy business tier price
STRIPE_ENTERPRISE_PRICE_ID=          # Legacy enterprise tier price

# ─── reCAPTCHA ─────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=                 # Google reCAPTCHA v3 secret key
RECAPT_SAFE_KEY=                      # Safe browsing / captcha verify key

# ─── Google Safe Browsing ──────────────────────────────────────────────────────
GOOGLE_SAFE_BROWSING_API_KEY=         # For URL threat intelligence checks

# ─── Crypto Intelligence (blockchain scanning) ────────────────────────────────
INFURA_API_KEY=
ALCHEMY_API_KEY=
HELIUS_API_KEY=
ETHERSCAN_API_KEY=
SOLANA_RPC_URL=https://mainnet.helius-rpc.com

# ─── Self-hosted MCP / API key ────────────────────────────────────────────────
AIVIS_API_KEY=                        # API key for MCP server integration
AIVIS_BASE_URL=                       # Base URL for MCP client calls

# ─── Licensing (Gumroad) ──────────────────────────────────────────────────────
LICENSE_ENCRYPTION_SECRET=            # Required in production for license features
GUMROAD_WEBHOOK_SECRET=               # Gumroad webhook signing secret

# ─── Background job toggles ──────────────────────────────────────────────────
DISABLE_BACKGROUND_JOBS=false         # Kill-switch for ALL background jobs
DISABLE_AUTOAutoFix PR=false            # Disable auto Score Fix pipeline
DISABLE_NEWSLETTER_LOOP=false         # Disable newsletter automation loop
DISABLE_COMPETITOR_AUTOPILOT=false    # Disable competitor auto-tracking
DISABLE_SCHEDULED_RESCANS=false       # Disable scheduled re-scan jobs

# ─── Referral system ──────────────────────────────────────────────────────────
REFERRAL_CREDITS_TO_REFERRER=5        # Scan credits given to referrer
REFERRAL_CREDITS_TO_REFERRED=5        # Scan credits given to new signup
REFERRAL_MIN_AUDITS_FOR_REWARD=1      # Audits required before reward triggers
REFERRAL_PAID_REWARD_MULTIPLIER=2     # Multiplier for paid-plan referral bonus

# ─── Access control ───────────────────────────────────────────────────────────
ELEVATED_TIER_ALLOWLIST_EMAILS=       # Comma-separated emails to auto-elevate tier
ADMIN_ELEVATED_ALLOWLIST_EMAILS=      # Comma-separated emails with admin-level access

# ─── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Google Analytics 4 Measurement Protocol (optional) ──────────────────────
GA4_MEASUREMENT_ID=G-B4WM53183L
GA4_API_SECRET=
GA_MEASUREMENT_ID=                    # Alias for GA4_MEASUREMENT_ID
GA_MEASUREMENT_PROTOCOL_SECRET=       # Alias for GA4_API_SECRET

# ─── Analytics telemetry ──────────────────────────────────────────────────────
ANALYTICS_ENABLED=true
ANALYTICS_ENDPOINT=https://api.aivis.biz/api/events
ANALYTICS_API_KEY=some_shared_secret
APP_NAME=AiVIS.biz