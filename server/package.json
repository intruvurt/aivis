{
  "name": "aivis-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server/src/server.js",
  "engines": {
    "node": ">=20.19.6"
  },
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "precommit": "node ./tools/precommit-runner.mjs",
    "install:all": "npm --prefix ../client install --include=dev && npm install --include=dev",
    "build:client": "npm --prefix ../client install --include=dev && npm --prefix ../client run build",
    "build:server": "tsc -p tsconfig.build.json",
    "build": "npm run build:client && npm run build:server",
    "start": "npm --prefix server run start",
    "format:check": "npm --prefix client run format:check",
    "lint": "npm --prefix client run lint && npm --prefix server run lint",
    "quality:lint": "npm --prefix client run lint && npm --prefix server run lint",
    "quality:format:check": "npm --prefix client run format:check",
    "typecheck": "npm --prefix client run typecheck && npm --prefix server run typecheck",
    "type-check": "npm run typecheck",
    "quality:typecheck": "npm --prefix client run typecheck && npm --prefix server run typecheck",
    "quality:test": "npm --prefix client test -- --run && npm --prefix server test",
    "quality:ci": "npm run quality:lint && npm run quality:format:check && npm run quality:typecheck && npm run quality:test",
    "api": "npm --prefix server run dev",
    "web": "npm --prefix client run dev",
    "worker": "npm --prefix server run worker",
    "worker:dev": "npm --prefix server run worker:dev",
    "queue:replay": "node ./tools/replay-queue.mjs",
    "queue:inspect": "node ./tools/inspect-queue.mjs",
    "smoke:features": "node ./tools/verify-feature-status-smoke.mjs",
    "smoke:analyze": "node ./tools/verify-analyze-integrity-smoke.mjs",
    "smoke:analyze:tiers": "node ./tools/verify-analyze-integrity-by-tier.mjs",
    "smoke:seed:tiers": "node ./tools/seed-tier-smoke-users.mjs",
    "smoke:prod": "node ./tools/verify-prod-endpoints-smoke.mjs",
    "smoke:prod:crawl": "node ./tools/verify-prod-crawl-surface.mjs",
    "smoke:visibility:gate": "node ./tools/verify-visibility-gate.mjs",
    "smoke:audit-trace:determinism": "npm --prefix server run verify:audit-trace-determinism",
    "smoke:wiring:static": "node ./tools/verify-platform-wiring-static.mjs",
    "audit:system-truth": "node ./tools/system-truth-validator.mjs",
    "worker:bix": "npm --prefix server run worker:bix",
    "worker:citations": "npm --prefix server run worker:citations",
    "worker:fix": "npm --prefix server run worker:fix",
    "queue:debug": "node ./tools/debug-queue.mjs",
    "system:health": "node ./tools/system-health.mjs",
    "bix:simulate": "node ./tools/simulate-bix.mjs",
    "audit:full": "npm run smoke:features && npm run smoke:analyze && npm run smoke:wiring:static && npm run smoke:audit-trace:determinism",
    "clean": "rm -rf node_modules client/node_modules server/node_modules"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/node": "^9.47.1",
    "@sentry/profiling-node": "^9.47.1",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cypress": "^13.17.0",
    "date-fns": "^2.30.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "linkedom": "^0.18.12",
    "mammoth": "^1.11.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "posthog-node": "^3.4.0",
    "puppeteer-core": "^24.37.5",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.1.3",
    "robots-parser": "^3.0.1",
    "stripe": "^17.7.0",
    "tesseract.js": "^7.0.0",
    "uuid": "9.0.1",
    "validator": "^13.15.26",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.10",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.15.10",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "chalk": "^5.6.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prompts": "^2.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "path-to-regexp": "^6.2.3",
    "minimatch": "^10.2.1",
    "undici": "^7.23.1",
    "html-encoding-sniffer": "2.0.0",
    "bullmq": {
      "uuid": "9.0.1"
    }
  }
}
