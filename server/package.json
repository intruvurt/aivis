    "@typescript-eslint/parser": "^8.56.0",
    "chalk": "^5.6.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prompts": "^2.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "path-to-regexp": "^6.2.3",
    "minimatch": "^10.2.1",
    "undici": "^7.23.1",
    "html-encoding-sniffer": "2.0.0",
    "bullmq": {
      "uuid": "9.0.1"
    }
  }
