{
  "name": "aivis-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server/src/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:server",
    "build:server": "tsc -p tsconfig.build.json",
    "start": "node --import ./dist/server/src/instrument.js dist/server/src/server.js",
    "start:prod": "node --import ./dist/server/src/instrument.js dist/server/src/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tools/**/*.ts\"",
    "test": "vitest run",
    "worker:bix": "tsx src/workers/bix.worker.ts",
    "worker:citations": "tsx src/workers/citation.worker.ts",
    "worker:fix": "tsx src/workers/fix.worker.ts",
    "verify:audit-trace-determinism": "tsx tools/verifyAuditTraceDeterminism.ts",
    "verify:determinism": "tsx tools/verifyDeterminism.ts",
    "smoke:analyze:e2e": "tsx tools/smokeAnalyzeCompilerE2E.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/node": "^9.47.1",
    "@sentry/profiling-node": "^9.47.1",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.1",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cypress": "^13.17.0",
    "date-fns": "^2.30.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "linkedom": "^0.18.12",
    "mammoth": "^1.11.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
