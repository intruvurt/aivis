{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "node",
    "target": "ES2024",
    "module": "esnext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.spec.ts", "migrations",
    "seeds", "tests", "scripts", "types", ".local", ".env", ".env.*"]
}
