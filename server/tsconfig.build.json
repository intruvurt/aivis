{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "rootDir": "..",
    "strict": false,
    "noImplicitAny": false,
    "declaration": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "../shared/**/*.ts",
    "../shared/**/*.d.ts",
    "tools/**/*.ts",
    "tools/**/*.d.ts",
    "src/tests/**/*.ts",
    "python/**/*.py"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/tests/**/*",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/vite.config.ts",
    "src/vitest.config.ts",
    "src/vitest.setup.ts",
    "src/tailwind.config.ts",
    "src/controllers/aiController.ts",
    "src/controllers/auditController.ts",
    "src/controllers/brandController.ts",
    "src/controllers/statusController.ts",
    "src/controllers/statusUpdateController.ts",
    "src/workers/exampleStreamWorker.template.ts",
    "src/routes/aiRoutes.ts",
    "src/routes/auditRoutes.ts",
    "src/routes/brand.ts",
    "src/routes/exportRoutes.ts",
    "src/routes/status.ts",
    "src/routes/statusUpdates.ts",
    "src/models/Audit.tsx",
    "src/models/Brand.tsx",
    "src/models/Website.tsx",
    "src/config/oauth.ts"
  ]
}
